# ============================================================================
# .gitignore - Tracker do Koda
# ============================================================================
# Arquivos e pastas que não devem ser versionados no Git
# ============================================================================

# ============================================================================
# DEPENDÊNCIAS E NODE
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================================================
# IDES E EDITORES
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.sublime-project
*.sublime-workspace

# ============================================================================
# LOGS E DEBUG
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================================================
# BUILD E DIST
# ============================================================================
dist/
build/
out/
.cache/

# ============================================================================
# VARIÁVEIS DE AMBIENTE E CONFIGURAÇÕES SENSÍVEIS
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.crt
secrets/

# ============================================================================
# BACKUPS E TEMPORÁRIOS
# ============================================================================
*.bak
*.backup
*.tmp
*.temp
*~
*.old

# ============================================================================
# TESTS E COVERAGE
# ============================================================================
coverage/
.nyc_output/
.jest/

# ============================================================================
# SQL LEGACY (JÁ MOVIDOS PARA DATABASE/LEGACY)
# ============================================================================
# Se precisar versionar SQLs antigos, use database/legacy/
# Não adicione SQLs na raiz do projeto

# ============================================================================
# DOCUMENTAÇÃO TEMPORÁRIA
# ============================================================================
TODO.md
NOTES.md
SCRATCHPAD.md
*.draft.md

# ============================================================================
# OS GENERATED FILES
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# FERRAMENTAS DE DESENVOLVIMENTO
# ============================================================================
.eslintcache
.stylelintcache
*.tgz

# ============================================================================
# SUPABASE/BACKUP (CUIDADO!)
# ============================================================================
# NUNCA commit backups completos do banco
# Use migrations em database/ ao invés disso
*.sql.backup
backup-*.sql
dump-*.sql

